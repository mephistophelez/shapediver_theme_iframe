{
  "version": "1.0",
  "themeOverrides": {
    "primaryColor": "violet",
    "colors": {
      "violet": [
        "#f3eeff",
        "#e0d0ff",
        "#c4a8ff",
        "#a87dff",
        "#9160fe",
        "#834ffe",
        "#7a44fe",
        "#6835e4",
        "#5c2dcc",
        "#4f22b4"
      ]
    },
    "other": {
      "forceColorScheme": "light"
    },
    "components": {
      "Slider": {
        "styles": {
          "track": { "backgroundColor": "#c0c0c0" },
          "bar":   { "backgroundColor": "#834ffe" },
          "thumb": { "borderColor": "#834ffe", "backgroundColor": "#834ffe" },
          "mark":       { "borderColor": "#834ffe" },
          "markFilled": { "borderColor": "#834ffe" }
        }
      },
      "Paper": {
        "defaultProps": {
          "withBorder": false,
          "shadow": "none",
          "bg": "transparent"
        },
        "styles": {
          "root": {
            "backgroundColor": "transparent",
            "boxShadow": "none",
            "border": "none"
          }
        }
      },
      "AppBuilderAppShellTemplatePage": {
        "defaultProps": {
          "navbarBackgroundColor": "transparent",
          "mainBackgroundColor": "transparent"
        }
      },
      "AppBuilderControlsWidgetComponent": {
        "defaultProps": {
          "elementPaperProps": {
            "withBorder": false,
            "shadow": "none",
            "style": { "backgroundColor": "transparent" }
          }
        }
      },
      "AppBuilderFormWidgetComponent": {
        "defaultProps": {
          "formPaperProps": {
            "withBorder": false,
            "shadow": "none",
            "style": { "backgroundColor": "transparent" }
          },
          "elementPaperProps": {
            "withBorder": false,
            "shadow": "none",
            "style": { "backgroundColor": "transparent" }
          }
        }
      },
      "AppBuilderStackUiWidgetComponent": {
        "defaultProps": {
          "stackPaperProps": {
            "withBorder": false,
            "shadow": "none",
            "style": { "backgroundColor": "transparent" }
          }
        }
      },
      "ParametersAndExportsAccordionComponent": {
        "defaultProps": {
          "accordionPaperProps": {
            "withBorder": false,
            "shadow": "none",
            "px": 0,
            "py": 0
          }
        }
      },
      "Accordion": {
        "defaultProps": {
          "variant": "default"
        },
        "styles": {
          "item": { "backgroundColor": "transparent", "border": "none" },
          "content": { "padding": "0", "backgroundColor": "transparent" },
          "control": { "backgroundColor": "transparent" },
          "panel": { "backgroundColor": "transparent" }
        }
      }
    }
  }
}
